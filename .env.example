# 将本文件复制为 .env 后填写真实配置；.env 已被 Git 忽略，绝不能提交真实密钥。

# 第一阶段使用阿里云百炼的 OpenAI 兼容接口。后续接入其他云服务或 Ollama 时再扩展可选值。
LLM_PROVIDER=bailian

# qwen3.6-flash 支持 Function Calling 和结构化输出，适合低成本、高频率的开发测试。
# 遇到复杂研究任务时，可以临时切换为 qwen3.7-plus 进行质量对比。
LLM_MODEL=qwen3.6-flash

# 这里只保留空占位符；真实密钥只能填写在本地 .env 文件中。
LLM_API_KEY=

# 将地址放入配置而不是写死在代码中，方便后续切换测试环境或其他 Provider。
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 非思考模式响应更快，也更适合第一阶段的工具调用与结构化输出测试。
# 后续复杂分析可设为 true，并额外评估延迟、成本和答案质量。
LLM_ENABLE_THINKING=false

# 较低温度让金融工具调用和结构化结果更稳定；取值范围为 [0, 2)。
LLM_TEMPERATURE=0.2

# 限制单次响应规模，防止调试阶段意外生成过长内容。
LLM_MAX_OUTPUT_TOKENS=1200

# 网络请求的超时和自动重试策略。
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# GoldAPI 只用于获取国际黄金 XAU/CNY 参考价，不能代替京东金融积存金卖出价。
# 真实密钥只能填写在本地 .env；本示例必须始终保留为空。
GOLDAPI_API_KEY=

# 把基础地址放入配置，便于测试时替换为假服务，也避免 Provider 内部散落硬编码。
GOLDAPI_BASE_URL=https://www.goldapi.io/api

# HTTP 客户端超时负责尽快释放失去响应的连接；应用层仍会保留统一的总超时保护。
GOLDAPI_TIMEOUT_SECONDS=10

# 免费额度有限，同一进程内的重复查询会复用 15 分钟缓存。
GOLDAPI_CACHE_TTL_SECONDS=900

# 默认使用固定 Fake 行情，运行自动测试和离线资产面板时不会访问任何外部接口。
# 只有明确改为 real 时才会装配 AKShare 与 GoldAPI，并要求配置 GOLDAPI_API_KEY。
MARKET_DATA_MODE=fake

# 京东积存金手工卖出价的有效期；默认 900 秒，严格超过后拒绝生成组合快照。
MANUAL_GOLD_PRICE_MAX_AGE_SECONDS=900
